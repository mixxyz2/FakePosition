--  SEARCH BAR HELPER
-- ════════════════════════════════════════════════════════════════════════════
local function makeSearchBar(parent, layoutOrder, borderColor, onChanged)
    local searchRow = Instance.new("Frame")
    searchRow.Size = UDim2.new(1, 0, 0, 36)
    searchRow.BackgroundColor3 = T.card
    searchRow.BorderSizePixel = 0
    searchRow.LayoutOrder = layoutOrder
    searchRow.Parent = parent
    corner(searchRow, 8)
    stroke(searchRow, borderColor or T.border, 1)

    local iconLbl = Instance.new("TextLabel")
    iconLbl.Size = UDim2.new(0, 30, 1, 0)
    iconLbl.Position = UDim2.new(0, 4, 0, 0)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text = "🔍"
    iconLbl.TextSize = 14
    iconLbl.Font = Enum.Font.Gotham
    iconLbl.TextColor3 = T.sub
    iconLbl.TextXAlignment = Enum.TextXAlignment.Center
    iconLbl.Parent = searchRow

    local searchBox = Instance.new("TextBox")
    searchBox.Size = UDim2.new(1, -44, 1, -10)
    searchBox.Position = UDim2.new(0, 34, 0, 5)
    searchBox.BackgroundTransparency = 1
    searchBox.BorderSizePixel = 0
    searchBox.PlaceholderText = "Search players..."
    searchBox.PlaceholderColor3 = T.sub
    searchBox.Text = ""
    searchBox.TextColor3 = T.text
    searchBox.TextSize = 12
    searchBox.Font = Enum.Font.Gotham
    searchBox.ClearTextOnFocus = false
    searchBox.Parent = searchRow

    searchBox.Focused:Connect(function()
        tw(searchRow, {BackgroundColor3 = T.cardH})
    end)
    searchBox.FocusLost:Connect(function()
        tw(searchRow, {BackgroundColor3 = T.card})
    end)

    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        if onChanged then onChanged(searchBox.Text) end
    end)

    return searchRow, searchBox
end

