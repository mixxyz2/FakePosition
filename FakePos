--  PERSISTENCE
-- ════════════════════════════════════════════════════════════════════════════
local function escStr(s) return tostring(s):gsub('"', '\\"') end
local function jsonNum(src, key) return tonumber(src:match('"'..key..'":([%-]?%d+)')) end
local function jsonStr(src, key) return src:match('"'..key..'":"([^"]*)"') end

local function serSettings()
    return string.format(
        '{"spoofKey":"%s","guiKey":"%s","stickEnabled":%s,"randomDir":%s,"fovEnabled":%s,"fovRange":%d}',
        state.spoofKey.Name, state.guiKey.Name,
        tostring(state.stickEnabled), tostring(state.randomDir),
        tostring(state.fovEnabled), state.fovRange
    )
end

local function serPresets()
    local p = {}
    for _, v in ipairs(customPresets) do
        p[#p+1] = string.format('{"name":"%s","x":%s,"y":%s,"z":%s}',
            escStr(v.name), v.x, v.y, v.z)
    end
    return "[" .. table.concat(p, ",") .. "]"
end

local function serAll()
    return string.format('{"settings":%s,"presets":%s}', serSettings(), serPresets())
end

local function saveAll()
    if writefile then pcall(writefile, SAVE_FILE, serAll()) end
end

local function loadAll()
    if not (readfile and isfile and isfile(SAVE_FILE)) then return end
    local ok, raw = pcall(readfile, SAVE_FILE)
    if not ok or not raw or raw == "" then return end
    local sb = raw:match('"settings":(%b{})'); local pb = raw:match('"presets":(%b[])')
    if sb then pcall(function()
        local sk = jsonStr(sb,"spoofKey"); local gk = jsonStr(sb,"guiKey")
        if sk then local o,k=pcall(function() return Enum.KeyCode[sk] end); if o and k then state.spoofKey=k end end
        if gk then local o,k=pcall(function() return Enum.KeyCode[gk] end); if o and k then state.guiKey=k end end
        state.stickEnabled = (sb:match('"stickEnabled":(%a+)') or "false") == "true"
        state.randomDir    = (sb:match('"randomDir":(%a+)')    or "false") == "true"
        state.fovEnabled   = (sb:match('"fovEnabled":(%a+)')   or "false") == "true"
        state.fovRange     = jsonNum(sb,"fovRange") or state.fovRange
    end) end
    if pb then pcall(function()
        for e in pb:gmatch("{(.-)}") do
            local n=e:match('"name":"([^"]*)"'); local x=tonumber(e:match('"x":([%-%.%d]+)'))
            local y=tonumber(e:match('"y":([%-%.%d]+)')); local z=tonumber(e:match('"z":([%-%.%d]+)'))
            if n and x and y and z then customPresets[#customPresets+1]={name=n,x=x,y=y,z=z} end
        end
    end) end
end
loadAll()

-- ════════════════════════════════════════════════════════════════════════════
--  SPOOF ENGINE
-- ════════════════════════════════════════════════════════════════════════════
local function stopSpoof()
    if spoofConn then spoofConn:Disconnect(); spoofConn = nil end
end

local function randomVec()
    local v = Vector3.new(
        math.random(-100,100)/100,
        math.random(  10,100)/100,
        math.random(-100,100)/100
    )
    if v.Magnitude < 0.01 then v = Vector3.new(0,1,0) end
    return v.Unit
end

local function startSpoof()
    stopSpoof()
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    spoofBasePos = hrp and hrp.Position or Vector3.zero
    state.randomDirVec   = randomVec()
    state.randomDirTimer = 0

    spoofConn = RunService.Heartbeat:Connect(function(dt)
        if not state.enabled then return end

        -- Base position
        local base
        if state.stickEnabled then
            local c = LocalPlayer.Character
            local h = c and c:FindFirstChild("HumanoidRootPart")
            base = h and h.Position or spoofBasePos
        else
            base = spoofBasePos
        end

        -- Compute fake position
        local fp
        if state.randomDir then
            state.randomDirTimer = state.randomDirTimer + dt
            if state.randomDirTimer >= 1.5 then
                state.randomDirTimer = 0
                state.randomDirVec   = randomVec()
            end
            local mag = math.sqrt(state.x^2 + state.y^2 + state.z^2)
            if mag < 1 then mag = 1000 end
            fp = base + state.randomDirVec * mag
        else
            fp = base + Vector3.new(state.x, state.y, state.z)
        end

        -- Apply to targeted players
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and (state.targetAll or targeted[p.Name]) then
                local c = p.Character
                local h = c and c:FindFirstChild("HumanoidRootPart")
                if h then h.CFrame = CFrame.new(fp) end
            end
        end
    end)
end

-- ════════════════════════════════════════════════════════════════════════════
--  FOV VISUALIZER
-- ════════════════════════════════════════════════════════════════════════════
local fovGui = nil
local FOV_SEGMENTS = 80

local function destroyFOVGui()
    if fovGui then fovGui:Destroy(); fovGui = nil end
end

local function buildFOVGui(parentGui)
    destroyFOVGui()
    fovGui = Instance.new("Frame")
    fovGui.Name = "FOVVisualizer"; fovGui.Size = UDim2.new(1,0,1,0)
    fovGui.BackgroundTransparency = 1; fovGui.ZIndex = 50; fovGui.Parent = parentGui

    local segs = {}
    for i = 1, FOV_SEGMENTS do
        local s = Instance.new("Frame"); s.Size = UDim2.new(0,2,0,2)
        s.BackgroundColor3 = Color3.fromRGB(255,220,60); s.BorderSizePixel = 0
        s.AnchorPoint = Vector2.new(0.5,0.5); s.ZIndex = 51; s.Parent = fovGui
        segs[i] = s
    end

    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not state.fovEnabled or not fovGui or not fovGui.Parent then
            conn:Disconnect(); return
        end
        local sz = fovGui.AbsoluteSize
        local cx, cy = sz.X/2, sz.Y/2
        local camFOV = workspace.CurrentCamera.FieldOfView
        local r = (math.tan(math.rad(state.fovRange)) / math.tan(math.rad(camFOV/2))) * (sz.Y/2)
        for i, s in ipairs(segs) do
            local a = (i/FOV_SEGMENTS)*math.pi*2
            s.Position = UDim2.new(0, cx+math.cos(a)*r, 0, cy+math.sin(a)*r)
            local b = 0.85 + 0.15*math.sin(a*3 + tick()*2)
            s.BackgroundColor3 = Color3.fromRGB(math.floor(255*b), math.floor(210*b), math.floor(40*b))
        end
    end)
end

