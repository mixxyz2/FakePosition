--  SPOOF
-- ════════════════════════════════════════════════════════════════════════════
local spoofBasePos = Vector3.zero

local function stopSpoof()
    if spoofConn then spoofConn:Disconnect(); spoofConn = nil end
end

local function randomVec()
    return Vector3.new(
        math.random(-100,100)/100,
        math.random(  0,100)/100,
        math.random(-100,100)/100
    ).Unit
end

local function startSpoof()
    stopSpoof()
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    spoofBasePos = hrp and hrp.Position or Vector3.zero

    state.randomDirVec   = randomVec()
    state.randomDirTimer = 0
    spoofConn = RunService.Heartbeat:Connect(function(dt)
        if not state.enabled then return end

        local base
        if state.stickEnabled then
            local char = LocalPlayer.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            base = hrp and hrp.Position or spoofBasePos
        else
            base = spoofBasePos
        end

        local fp
        if state.randomDir then
            state.randomDirTimer = state.randomDirTimer + dt
            if state.randomDirTimer >= 1.5 then
                state.randomDirTimer = 0
                state.randomDirVec   = randomVec()
            end
            local mag = math.sqrt(state.x^2 + state.y^2 + state.z^2)
            if mag < 1 then mag = 1000 end
            fp = base + state.randomDirVec * mag
        else
            fp = base + Vector3.new(state.x, state.y, state.z)
        end

        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and (state.targetAll or targeted[p.Name]) then
                local c = p.Character; local h = c and c:FindFirstChild("HumanoidRootPart")
                if h then h.CFrame = CFrame.new(fp) end
            end
        end
    end)
end

