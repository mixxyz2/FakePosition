local function safeFire()
    if type(mouse1click) == "function" then
        pcall(mouse1click)
    elseif type(mouse1press) == "function" then
        pcall(mouse1press)
        task.wait(0.01)
        if type(mouse1release) == "function" then pcall(mouse1release) end
    end
end

-- ─── Nearest-target helper ────────────────────────────────────────────────
local function getNearestTarget(fovLimit, boneName)
    local cam    = workspace.CurrentCamera
    local vp     = cam.ViewportSize
    local center = Vector2.new(vp.X / 2, vp.Y / 2)
    local best, bestDist = nil, fovLimit or math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local bone = p.Character:FindFirstChild(boneName or "Head")
                          or p.Character:FindFirstChild("HumanoidRootPart")
                if bone then
                    local sp, onScreen = cam:WorldToViewportPoint(bone.Position)
                    if onScreen then
                        local dist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                        if dist < bestDist then best = p; bestDist = dist end
                    end
                end
            end
        end
    end
    return best
end

