    local function makeKeybindCard(parent, descText, getKey, setKey, lo)
        local kbCard = Instance.new("Frame"); kbCard.Size = UDim2.new(1,0,0,44); kbCard.LayoutOrder = lo or 0
        kbCard.BackgroundColor3 = T.card; kbCard.BorderSizePixel = 0; kbCard.Parent = parent; corner(kbCard,8); stroke(kbCard,T.border)
        local kbDesc = Instance.new("TextLabel"); kbDesc.Size = UDim2.new(1,-110,1,0); kbDesc.Position = UDim2.new(0,12,0,0)
        kbDesc.BackgroundTransparency = 1; kbDesc.Text = descText; kbDesc.TextSize = 12; kbDesc.Font = Enum.Font.Gotham; kbDesc.TextColor3 = T.text
        kbDesc.TextXAlignment = Enum.TextXAlignment.Left; kbDesc.Parent = kbCard
        local kbBtn = Instance.new("TextButton"); kbBtn.Size = UDim2.new(0,90,0,28); kbBtn.Position = UDim2.new(1,-98,0.5,-14)
        kbBtn.BackgroundColor3 = T.surface; kbBtn.BorderSizePixel = 0; kbBtn.Text = getKey().Name; kbBtn.TextSize = 11; kbBtn.Font = Enum.Font.GothamBold
        kbBtn.TextColor3 = T.accent; kbBtn.AutoButtonColor = false; kbBtn.Parent = kbCard; corner(kbBtn,6); stroke(kbBtn,T.accentD)
        local listening = false
        kbBtn.MouseButton1Click:Connect(function()
            if listening then return end; listening = true; kbBtn.Text = "..."; kbBtn.TextColor3 = T.yellow
            local conn; conn = UserInputService.InputBegan:Connect(function(inp,gp)
                if gp then return end
                if inp.UserInputType == Enum.UserInputType.Keyboard then
                    setKey(inp.KeyCode); kbBtn.Text = inp.KeyCode.Name; kbBtn.TextColor3 = T.accent
                    tw(kbBtn,{BackgroundColor3=T.surface}); listening = false; conn:Disconnect(); saveAll()
                end
            end)
        end)
        kbBtn.MouseEnter:Connect(function() if not listening then tw(kbBtn,{BackgroundColor3=T.card}) end end)
        kbBtn.MouseLeave:Connect(function() if not listening then tw(kbBtn,{BackgroundColor3=T.surface}) end end)
    end

    local spoofBusy, guiBusy = false, false
    makeKeybindCard(settingsPage,"Toggle Spoof On/Off",
        function() return state.spoofKey end, function(k) state.spoofKey=k end, 1)
    makeKeybindCard(settingsPage,"Open / Close Menu",
        function() return state.guiKey end, function(k) state.guiKey=k end, 2)

    -- FOV visualizer toggle
    sectionLabel(settingsPage,"FOV VISUALIZER",3)
    local fovCard = Instance.new("Frame"); fovCard.Size = UDim2.new(1,0,0,44); fovCard.LayoutOrder = 4
    fovCard.BackgroundColor3 = T.card; fovCard.BorderSizePixel = 0; fovCard.Parent = settingsPage; corner(fovCard,8); stroke(fovCard,T.border)
    local fovLbl = Instance.new("TextLabel"); fovLbl.Size = UDim2.new(1,-60,1,0); fovLbl.Position = UDim2.new(0,12,0,0)
    fovLbl.BackgroundTransparency = 1; fovLbl.Text = "Show FOV Circle"; fovLbl.TextSize = 13; fovLbl.Font = Enum.Font.GothamBold
    fovLbl.TextColor3 = T.text; fovLbl.TextXAlignment = Enum.TextXAlignment.Left; fovLbl.Parent = fovCard
    local _fovPill, setFovPill = makePillToggle(fovCard, state.fovEnabled, function(v)
        state.fovEnabled = v
        if v then buildFOVGui(gui) else destroyFOVGui() end; saveAll()
    end)
    _fovPill.Position = UDim2.new(1,-52,0.5,-11); _fovPill.Parent = fovCard
    makeSlider(settingsPage,"FOV RANGE",5,180,state.fovRange,function(v) state.fovRange=v; saveAll() end, T.yellow)

    -- File info
    sectionLabel(settingsPage,"FILE",6)
    local fileCard = Instance.new("Frame"); fileCard.Size = UDim2.new(1,0,0,44); fileCard.LayoutOrder = 7
    fileCard.BackgroundColor3 = T.card; fileCard.BorderSizePixel = 0; fileCard.Parent = settingsPage; corner(fileCard,8); stroke(fileCard,T.border)
    local fTitle = Instance.new("TextLabel"); fTitle.Size = UDim2.new(1,-20,0,20); fTitle.Position = UDim2.new(0,12,0,6)
    fTitle.BackgroundTransparency = 1; fTitle.Text = "Preset + Settings Storage"; fTitle.TextSize = 12; fTitle.Font = Enum.Font.GothamBold
    fTitle.TextColor3 = T.text; fTitle.TextXAlignment = Enum.TextXAlignment.Left; fTitle.Parent = fileCard
    local fSub = Instance.new("TextLabel"); fSub.Size = UDim2.new(1,-20,0,14); fSub.Position = UDim2.new(0,12,0,26)
    fSub.BackgroundTransparency = 1
    fSub.Text = (writefile and isfile) and "● Saving to "..SAVE_FILE or "● writefile unavailable — session only"
    fSub.TextSize = 10; fSub.Font = Enum.Font.Gotham; fSub.TextXAlignment = Enum.TextXAlignment.Left
    fSub.TextColor3 = (writefile and isfile) and T.accent or T.red; fSub.Parent = fileCard

    -- Unload
    sectionLabel(settingsPage,"DANGER ZONE",8)
    local unloadBtn = Instance.new("TextButton"); unloadBtn.Size = UDim2.new(1,0,0,40); unloadBtn.LayoutOrder = 9
    unloadBtn.BackgroundColor3 = Color3.fromRGB(50,14,14); unloadBtn.BorderSizePixel = 0
    unloadBtn.Text = "⏏  Unload UI  (destroys everything)"; unloadBtn.TextSize = 12; unloadBtn.Font = Enum.Font.GothamBold
    unloadBtn.TextColor3 = T.red; unloadBtn.AutoButtonColor = false; unloadBtn.Parent = settingsPage; corner(unloadBtn,8); stroke(unloadBtn,T.red,1)
    unloadBtn.MouseEnter:Connect(function() tw(unloadBtn,{BackgroundColor3=Color3.fromRGB(72,18,18)}) end)
    unloadBtn.MouseLeave:Connect(function() tw(unloadBtn,{BackgroundColor3=Color3.fromRGB(50,14,14)}) end)
    local unloadConfirm = false
    unloadBtn.MouseButton1Click:Connect(function()
        if not unloadConfirm then
            unloadConfirm = true; unloadBtn.Text = "⚠  Click again to confirm"
            tw(unloadBtn,{BackgroundColor3=Color3.fromRGB(100,30,10)})
            task.delay(3, function() unloadConfirm = false; unloadBtn.Text = "⏏  Unload UI  (destroys everything)"; tw(unloadBtn,{BackgroundColor3=Color3.fromRGB(50,14,14)}) end)
        else
            saveAll(); cleanup()
        end
    end)

    -- Keybind listener (runs after cards are built so no forward-ref issues)
    UserInputService.InputBegan:Connect(function(inp, gp)
        if gp then return end
        if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
        if inp.KeyCode == state.spoofKey then
            state.enabled = not state.enabled
            if state.enabled then startSpoof() end; updateStatus()
        elseif inp.KeyCode == state.guiKey then
            setGuiVisible(not guiVisible)
        end
    end)

    -- ════════════════════════════════════════════════════════════════════
    --  MOBILE-ONLY RIGHT-SIDE BUTTON PANEL
    --  Visible only on TouchEnabled devices (phones/tablets).
    --  Buttons: Toggle UI | Lock UI
    --  Styled to match the screenshot — dark bg, red border, plain text.
    -- ════════════════════════════════════════════════════════════════════
    local isMobile = UserInputService.TouchEnabled and not UserInputService.MouseEnabled

    if isMobile then
        local BTN_W    = 110
        local BTN_H    = 46
        local BTN_GAP  = 8
        local BTN_PADX = 10   -- from right edge
        local BTN_PADY = 120  -- from top

        -- Container so buttons move together
        local mobilePanel = Instance.new("Frame")
        mobilePanel.Name                = "MobilePanel"
        mobilePanel.Size                = UDim2.new(0, BTN_W, 0, BTN_H*2 + BTN_GAP)
        mobilePanel.Position            = UDim2.new(1, -(BTN_W + BTN_PADX), 0, BTN_PADY)
        mobilePanel.BackgroundTransparency = 1
        mobilePanel.ZIndex              = 30
        mobilePanel.Parent              = gui

        local function makeMobileBtn(labelText, yOffset, onClick)
            local btn = Instance.new("TextButton")
            btn.Size                = UDim2.new(1, 0, 0, BTN_H)
            btn.Position            = UDim2.new(0, 0, 0, yOffset)
            btn.BackgroundColor3    = Color3.fromRGB(8, 8, 8)
            btn.BorderSizePixel     = 0
            btn.Text                = labelText
            btn.TextSize            = 14
            btn.Font                = Enum.Font.GothamBold
            btn.TextColor3          = Color3.fromRGB(220, 220, 220)
            btn.AutoButtonColor     = false
            btn.ZIndex              = 31
            btn.Parent              = mobilePanel
            corner(btn, 4)
            -- Red border matching screenshot
            local s = Instance.new("UIStroke")
            s.Color     = Color3.fromRGB(180, 30, 30)
            s.Thickness = 2
            s.Parent    = btn

            btn.MouseButton1Click:Connect(onClick)

            -- Press feedback
            btn.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.Touch then
                    tw(btn, {BackgroundColor3 = Color3.fromRGB(30, 8, 8)})
                end
            end)
            btn.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.Touch then
                    tw(btn, {BackgroundColor3 = Color3.fromRGB(8, 8, 8)})
                end
            end)

            return btn
        end

        -- Toggle UI button
        makeMobileBtn("Toggle UI", 0, function()
            setGuiVisible(not guiVisible)
        end)

        -- Lock UI button — prevents dragging when locked
        local lockBtn
        lockBtn = makeMobileBtn("Lock UI", BTN_H + BTN_GAP, function()
            guiLocked = not guiLocked
            -- Visual feedback: border turns green when locked
            local s = lockBtn:FindFirstChildOfClass("UIStroke")
            if s then
                s.Color = guiLocked and Color3.fromRGB(60,180,80) or Color3.fromRGB(180,30,30)
            end
            lockBtn.Text = guiLocked and "Locked 🔒" or "Lock UI"
        end)

        -- Make the panel itself draggable so players can reposition it
        local panDragging, panStart, panOrig = false, nil, nil
        mobilePanel.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Touch then
                panDragging = true; panStart = inp.Position; panOrig = mobilePanel.Position
            end
        end)
        mobilePanel.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Touch then panDragging = false end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if panDragging and inp.UserInputType == Enum.UserInputType.Touch then
                local d = inp.Position - panStart
                mobilePanel.Position = UDim2.new(
                    panOrig.X.Scale, panOrig.X.Offset + d.X,
                    panOrig.Y.Scale, panOrig.Y.Offset + d.Y
                )
            end
        end)
    end

    -- ── Init ──────────────────────────────────────────────────────────
    switchTab(1); rebuildTargets(); updateStatus()
end

-- ════════════════════════════════════════════════════════════════════════════
--  BOOT
-- ════════════════════════════════════════════════════════════════════════════
local function init()
    cleanup(); buildGUI()
    state.enabled = true; startSpoof()
end

init()
