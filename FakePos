--  FOV VISUALIZER
-- ════════════════════════════════════════════════════════════════════════════
local fovGui = nil
local FOV_SEGMENTS = 80

local function destroyFOVGui()
    if fovGui then fovGui:Destroy(); fovGui = nil end
end

local function buildFOVGui(parentGui)
    destroyFOVGui()
    fovGui = Instance.new("Frame")
    fovGui.Name               = "FOVVisualizer"
    fovGui.Size               = UDim2.new(1, 0, 1, 0)
    fovGui.BackgroundTransparency = 1
    fovGui.ZIndex             = 50
    fovGui.Parent             = parentGui

    local lines = {}
    for i = 1, FOV_SEGMENTS do
        local seg = Instance.new("Frame")
        seg.Size               = UDim2.new(0, 2, 0, 2)
        seg.BackgroundColor3   = Color3.fromRGB(255, 220, 60)
        seg.BorderSizePixel    = 0
        seg.AnchorPoint        = Vector2.new(0.5, 0.5)
        seg.ZIndex             = 51
        seg.Parent             = fovGui
        lines[i] = seg
    end

    local fovUpdateConn
    fovUpdateConn = RunService.RenderStepped:Connect(function()
        if not state.fovEnabled or not fovGui or not fovGui.Parent then
            fovUpdateConn:Disconnect(); return
        end

        local screenSize = fovGui.AbsoluteSize
        local cx = screenSize.X / 2
        local cy = screenSize.Y / 2

        local camFOV    = workspace.CurrentCamera.FieldOfView
        local halfFOV   = math.rad(camFOV / 2)
        local halfRange = math.rad(state.fovRange)
        local screenRadius = (math.tan(halfRange) / math.tan(halfFOV)) * (screenSize.Y / 2)

        for i, seg in ipairs(lines) do
            local angle = (i / FOV_SEGMENTS) * math.pi * 2
            local px    = cx + math.cos(angle) * screenRadius
            local py    = cy + math.sin(angle) * screenRadius
            seg.Position = UDim2.new(0, px, 0, py)
            local bright = 0.85 + 0.15 * math.sin(angle * 3 + tick() * 2)
            seg.BackgroundColor3 = Color3.fromRGB(
                math.floor(255 * bright),
                math.floor(210 * bright),
                math.floor(40  * bright)
