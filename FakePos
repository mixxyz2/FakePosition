    lbl.Text=lText; lbl.TextSize=11; lbl.Font=Enum.Font.GothamBold; lbl.TextColor3=T.sub
    lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.Parent=hdr

    local valBox=Instance.new("TextBox"); valBox.Size=UDim2.new(0.35,-2,1,2); valBox.Position=UDim2.new(0.45,2,0,-1)
    valBox.BackgroundColor3=T.inputBG; valBox.BorderSizePixel=0; valBox.Text=tostring(defV)
    valBox.PlaceholderText="value"; valBox.PlaceholderColor3=T.sub; valBox.TextColor3=ac
    valBox.TextSize=12; valBox.Font=Enum.Font.GothamBold; valBox.TextXAlignment=Enum.TextXAlignment.Right
    valBox.ClearTextOnFocus=false; valBox.ZIndex=6; valBox.Parent=hdr; corner(valBox,5); stroke(valBox,acd,1)
    local vbPad=Instance.new("UIPadding"); vbPad.PaddingRight=UDim.new(0,5); vbPad.Parent=valBox

    local resetBtn=Instance.new("TextButton"); resetBtn.Size=UDim2.new(0.18,-2,1,2)
    resetBtn.Position=UDim2.new(0.82,2,0,-1)
    resetBtn.BackgroundColor3=T.surface; resetBtn.BorderSizePixel=0; resetBtn.Text="↺"
    resetBtn.TextColor3=T.sub; resetBtn.TextSize=13; resetBtn.Font=Enum.Font.GothamBold
    resetBtn.AutoButtonColor=false; resetBtn.ZIndex=6; resetBtn.Parent=hdr; corner(resetBtn,5); stroke(resetBtn,acd,1)
    resetBtn.MouseEnter:Connect(function() tw(resetBtn,{BackgroundColor3=T.cardH,TextColor3=ac}) end)
    resetBtn.MouseLeave:Connect(function() tw(resetBtn,{BackgroundColor3=T.surface,TextColor3=T.sub}) end)

    local track=Instance.new("Frame"); track.Size=UDim2.new(1,-24,0,4); track.Position=UDim2.new(0,12,0,58)
    track.BackgroundColor3=T.border; track.BorderSizePixel=0; track.Parent=wrap; corner(track,4)

    local fill=Instance.new("Frame"); fill.Size=UDim2.new(0,0,1,0); fill.BackgroundColor3=ac
    fill.BorderSizePixel=0; fill.Parent=track; corner(fill,4)

    local thumb=Instance.new("Frame"); thumb.Size=UDim2.new(0,THUMB,0,THUMB)
    thumb.Position=UDim2.new(0,-THUMB/2,0.5,-THUMB/2); thumb.BackgroundColor3=Color3.fromRGB(238,238,238)
    thumb.BorderSizePixel=0; thumb.ZIndex=5; thumb.Parent=track; corner(thumb,THUMB/2); stroke(thumb,acd,1.5)

    local cur=defV
    local function updateVisual(v)
        local pct=math.clamp((v-minV)/(maxV-minV),0,1)
        fill.Size=UDim2.new(pct,0,1,0); thumb.Position=UDim2.new(pct,-THUMB/2,0.5,-THUMB/2)
    end
    local function setV(v,fire)
        v=math.clamp(math.floor(v+0.5),minV,maxV); cur=v
        updateVisual(v)
        valBox.Text=tostring(v); if fire and onChange then onChange(v) end
    end
    local function setVTyped(v,fire)
        v=math.floor(v+0.5); cur=v
        updateVisual(v)
        valBox.Text=tostring(v); if fire and onChange then onChange(v) end
    end
    setV(defV,false)

    resetBtn.MouseButton1Click:Connect(function()
        setV(defV,true)
        tw(resetBtn,{BackgroundColor3=T.accentD}); task.delay(0.3,function() tw(resetBtn,{BackgroundColor3=T.surface}) end)
    end)

    local function fromInput(inp)
        local ax=track.AbsolutePosition.X; local aw=track.AbsoluteSize.X
        local pct=math.clamp((inp.Position.X-ax)/aw,0,1); setV(minV+pct*(maxV-minV),true)
    end
    local function startDrag(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
            activeSliderFn=fromInput; fromInput(inp)
        end
    end
    track.InputBegan:Connect(startDrag); thumb.InputBegan:Connect(startDrag)
    track.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
            tw(thumb,{Size=UDim2.new(0,THUMB+4,0,THUMB+4)})
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
            tw(thumb,{Size=UDim2.new(0,THUMB,0,THUMB)})
        end
    end)
    valBox.Focused:Connect(function() tw(valBox,{BackgroundColor3=Color3.fromRGB(45,55,45)}) end)
    valBox.FocusLost:Connect(function()
        tw(valBox,{BackgroundColor3=T.inputBG})
        local num=tonumber(valBox.Text:match("^%s*([%-]?%d*%.?%d*)%s*$"))
        if num then setVTyped(num,true) else valBox.Text=tostring(cur) end
    end)
    wrap.MouseEnter:Connect(function() tw(wrap,{BackgroundColor3=T.cardH}) end)
    wrap.MouseLeave:Connect(function() tw(wrap,{BackgroundColor3=T.card})  end)

    return wrap, function() return cur end, setV
end

