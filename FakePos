local function makePillToggle(parent, initVal, onChange)
    local pill = Instance.new("Frame"); pill.Size = UDim2.new(0,40,0,22)
    pill.BackgroundColor3 = initVal and T.accent or T.border; pill.BorderSizePixel = 0; pill.Parent = parent; corner(pill,11)
    local knob = Instance.new("Frame"); knob.Size = UDim2.new(0,15,0,15)
    knob.Position = initVal and UDim2.new(1,-18,0.5,-7.5) or UDim2.new(0,3,0.5,-7.5)
    knob.BackgroundColor3 = Color3.fromRGB(240,240,240); knob.BorderSizePixel = 0; knob.Parent = pill; corner(knob,8)
    local val = initVal
    local function setV(v, animate)
        val = v; local t = animate and 0.15 or 0
        TweenService:Create(pill, TweenInfo.new(t), {BackgroundColor3 = v and T.accent or T.border}):Play()
        TweenService:Create(knob, TweenInfo.new(t), {Position = v and UDim2.new(1,-18,0.5,-7.5) or UDim2.new(0,3,0.5,-7.5)}):Play()
    end
    local click = Instance.new("TextButton"); click.Size = UDim2.new(1,0,1,0)
    click.BackgroundTransparency = 1; click.Text = ""; click.ZIndex = 3; click.Parent = pill
    click.MouseButton1Click:Connect(function() val = not val; setV(val,true); if onChange then onChange(val) end end)
    return pill, setV, function() return val end
end

local activeSliderFn = nil
UserInputService.InputChanged:Connect(function(i)
    if activeSliderFn and (i.UserInputType == Enum.UserInputType.MouseMovement or
