    -- ════════════════════════════════════════════════════════════════════
    --  TARGETS PAGE  (with search)
    -- ════════════════════════════════════════════════════════════════════
    local targetSearchQuery = ""
    local _targetSearchBar, targetSearchBox = makeSearchBar(targetPage, -1, T.accentD, function(q)
        targetSearchQuery = q
        -- rebuildTargets is declared below; Lua forward-ref is fine via upvalue
    end)

    local targetRowsList = {}
    local function rebuildTargets()
        for _,r in pairs(targetRowsList) do r:Destroy() end; targetRowsList = {}
        local q = targetSearchQuery:lower()

        -- "Target All" row — always visible
        local taRow=Instance.new("Frame"); taRow.Size=UDim2.new(1,0,0,50); taRow.LayoutOrder=0
        taRow.BackgroundColor3=T.card; taRow.BorderSizePixel=0; taRow.Parent=targetPage; corner(taRow,10)
