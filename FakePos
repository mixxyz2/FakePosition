--  ORBIT ENGINE
-- ════════════════════════════════════════════════════════════════════════════
local function stopOrbit()
    if orbitConn then orbitConn:Disconnect(); orbitConn = nil end
end

local function startOrbit()
    stopOrbit()
    state.orbitAngle = 0
    state.randomDirTimer = 0
    state.randomDirVec   = randomVec()
    local dirMult = 1

    orbitConn = RunService.Heartbeat:Connect(function(dt)
        if not state.orbitEnabled then stopOrbit(); return end

        if state.randomDir then
            state.randomDirTimer = state.randomDirTimer + dt
            if state.randomDirTimer >= 2.0 then
                state.randomDirTimer = 0
                dirMult = (math.random(0,1) == 0) and 1 or -1
            end
        else
            dirMult = 1
        end

        state.orbitAngle = state.orbitAngle + dt * state.orbitSpeed * dirMult
        local ox = math.cos(state.orbitAngle) * state.orbitDistance
        local oz = math.sin(state.orbitAngle) * state.orbitDistance
        local oy = state.orbitHeight

        if state.orbitReverse then
            local char = LocalPlayer.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end

            local anchor = nil
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and (state.targetAll or orbitTargeted[p.Name]) then
                    local c = p.Character; local h = c and c:FindFirstChild("HumanoidRootPart")
                    if h then anchor = h.Position; break end
                end
            end
            if anchor then
                hrp.CFrame = CFrame.new(anchor + Vector3.new(ox, oy, oz))
            end
        else
            local char = LocalPlayer.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            local base = hrp and hrp.Position or Vector3.zero
            local fp   = base + Vector3.new(ox, oy, oz)

            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and (state.targetAll or orbitTargeted[p.Name]) then
                    local c = p.Character; local h = c and c:FindFirstChild("HumanoidRootPart")
                    if h then h.CFrame = CFrame.new(fp) end
                end
            end
        end
    end)
end

