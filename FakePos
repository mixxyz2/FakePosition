-- ════════════════════════════════════════════════════════════════════════════
local function makeToggleCard(parent, labelText, descText, initVal, order, onCol, onChange)
    local oc = onCol or T.accent
    local card=Instance.new("Frame"); card.Size=UDim2.new(1,0,0,54); card.LayoutOrder=order or 0
    card.BackgroundColor3=T.card; card.BorderSizePixel=0; card.Parent=parent; corner(card,10); stroke(card,T.border)

    local lbl=Instance.new("TextLabel"); lbl.Size=UDim2.new(1,-60,0,20); lbl.Position=UDim2.new(0,14,0,8)
    lbl.BackgroundTransparency=1; lbl.Text=labelText; lbl.TextSize=13; lbl.Font=Enum.Font.GothamBold
    lbl.TextColor3=T.text; lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.Parent=card

    local desc=Instance.new("TextLabel"); desc.Size=UDim2.new(1,-60,0,14); desc.Position=UDim2.new(0,14,0,30)
    desc.BackgroundTransparency=1; desc.Text=descText; desc.TextSize=10; desc.Font=Enum.Font.Gotham
    desc.TextColor3=T.sub; desc.TextXAlignment=Enum.TextXAlignment.Left; desc.Parent=card

    local _pill, setPill = makePillToggleColored(card, initVal, oc, T.border, onChange)
    _pill.Position=UDim2.new(1,-52,0.5,-11); _pill.Parent=card

    card.MouseEnter:Connect(function() tw(card,{BackgroundColor3=T.cardH}) end)
    card.MouseLeave:Connect(function() tw(card,{BackgroundColor3=T.card})  end)
    return card, setPill
end

