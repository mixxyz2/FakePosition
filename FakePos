local function makeSlider(parent, lText, minV, maxV, defV, onChange, accentColor)
    local THUMB = 16
    local ac = accentColor or T.accent
    local acd = T.accentD

    local wrap=Instance.new("Frame"); wrap.Size=UDim2.new(1,0,0,78)
    wrap.BackgroundColor3=T.card; wrap.BorderSizePixel=0; wrap.Parent=parent; corner(wrap,10)

    local hdr=Instance.new("Frame"); hdr.Size=UDim2.new(1,-24,0,18); hdr.Position=UDim2.new(0,12,0,8)
