-- ════════════════════════════════════════════════════════════════════════════
--  COLLISION FIX
--  Ensure the LOCAL player's character parts always have normal collision.
--  This runs every Stepped frame and is the authoritative fix — nothing in
--  this script touches other players' CanCollide, so they are unaffected.
-- ════════════════════════════════════════════════════════════════════════════
RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") and not p.CanCollide then
            -- Only restore if it was we who disabled it (no external scripts assumed)
            -- We never disable our own collision in this script, so anything
            -- false here was set by a prior noclip remnant — restore it.
            p.CanCollide = true
        end
    end
end)

