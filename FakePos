local function jsonBool(src, key) local v = src:match('"'..key..'":(%a+)'); return v == "true" end
local function jsonNum(src, key)  return tonumber(src:match('"'..key..'":([%-]?%d+)')) end
local function jsonStr(src, key)  return src:match('"'..key..'":"([^"]*)"') end

local function parseSettings(src)
    local sk = jsonStr(src, "spoofKey"); local gk = jsonStr(src, "guiKey")
    if sk then local ok,kc=pcall(function() return Enum.KeyCode[sk] end); if ok and kc then state.spoofKey=kc end end
    if gk then local ok,kc=pcall(function() return Enum.KeyCode[gk] end); if ok and kc then state.guiKey=kc end end
    local eb = src:match('"espEnabled":(%a+)'); if eb then state.espEnabled=(eb=="true") end
    state.espR      = jsonNum(src,"espR")      or state.espR
    state.espG      = jsonNum(src,"espG")      or state.espG
    state.espB      = jsonNum(src,"espB")      or state.espB
    state.espBox    = (src:match('"espBox":(%a+)')    or "true")  == "true"
    state.espName   = (src:match('"espName":(%a+)')   or "true")  == "true"
    state.espHealth = (src:match('"espHealth":(%a+)') or "true")  == "true"
    state.espDist   = (src:match('"espDist":(%a+)')   or "true")  == "true"
    state.espTracer = (src:match('"espTracer":(%a+)') or "false") == "true"
    state.randomDir = (src:match('"randomDir":(%a+)') or "false") == "true"
    state.flySpeed  = jsonNum(src,"flySpeed")  or state.flySpeed
    state.flyHeight = jsonNum(src,"flyHeight") or state.flyHeight
    state.fovEnabled= (src:match('"fovEnabled":(%a+)') or "false") == "true"
    state.fovRange  = jsonNum(src,"fovRange")  or state.fovRange
    state.orbitSpeed    = jsonNum(src,"orbitSpeed")    or state.orbitSpeed
    state.orbitDistance = jsonNum(src,"orbitDistance") or state.orbitDistance
    state.orbitHeight   = jsonNum(src,"orbitHeight")   or state.orbitHeight
    state.orbitReverse  = (src:match('"orbitReverse":(%a+)') or "false") == "true"
end

local function parsePresets(json)
    local r = {}
    for e in json:gmatch("{(.-)}") do
        local n=e:match('"name":"([^"]*)"'); local x=tonumber(e:match('"x":([%-%.%d]+)'))
        local y=tonumber(e:match('"y":([%-%.%d]+)')); local z=tonumber(e:match('"z":([%-%.%d]+)'))
        if n and x and y and z then r[#r+1]={name=n,x=x,y=y,z=z} end
    end
    return r
end

local function parseSettingsPresets(json)
    local r = {}
    for e in json:gmatch("{(.-)}") do
        local n = e:match('"name":"([^"]*)"')
        if n then
            local function gb(k) return (e:match('"'..k..'":(%a+)') or "false")=="true" end
            local function gn(k) return tonumber(e:match('"'..k..'":([%-]?%d+)')) end
            local function gs(k) return e:match('"'..k..'":"([^"]*)"') end
            r[#r+1] = {
                name         = n,
                spoofKey     = gs("spoofKey")     or "RightControl",
                guiKey       = gs("guiKey")       or "RightShift",
                espEnabled   = gb("espEnabled"),
                espR         = gn("espR")         or 122,
                espG         = gn("espG")         or 186,
                espB         = gn("espB")         or 136,
                espBox       = gb("espBox"),
                espName      = gb("espName"),
                espHealth    = gb("espHealth"),
                espDist      = gb("espDist"),
                espTracer    = gb("espTracer"),
                randomDir    = gb("randomDir"),
                flySpeed     = gn("flySpeed")     or 50,
                flyHeight    = gn("flyHeight")    or 10,
                fovEnabled   = gb("fovEnabled"),
                fovRange     = gn("fovRange")     or 60,
                orbitSpeed   = gn("orbitSpeed")   or 1,
                orbitDistance= gn("orbitDistance")or 20,
                orbitHeight  = gn("orbitHeight")  or 0,
                orbitReverse = gb("orbitReverse"),
            }
        end
    end
    return r
end

local function saveAll()
    if writefile then pcall(writefile, SAVE_FILE, serAll()) end
end

local function loadAll()
    if not (readfile and isfile and isfile(SAVE_FILE)) then return end
    local ok, raw = pcall(readfile, SAVE_FILE); if not ok or not raw or raw=="" then return end
    local settingsBlock        = raw:match('"settings":(%b{})')
    local presetsBlock         = raw:match('"presets":(%b[])')
    local settingsPresetsBlock = raw:match('"settingsPresets":(%b[])')
    if settingsBlock        then pcall(parseSettings,        settingsBlock) end
    if presetsBlock         then customPresets   = parsePresets(presetsBlock)         else customPresets   = parsePresets(raw) end
    if settingsPresetsBlock then settingsPresets = parseSettingsPresets(settingsPresetsBlock) end
end
loadAll()

