--  RAGEBOT ENGINE
-- ════════════════════════════════════════════════════════════════════════════

-- Target-selection helpers
local function getRagebotTarget()
    local mode = state.ragebotTargetMode
    local cam  = workspace.CurrentCamera
    local camPos = cam.CFrame.Position

    local candidates = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local bone = p.Character:FindFirstChild(state.ragebotBone)
                          or p.Character:FindFirstChild("Head")
                          or p.Character:FindFirstChild("HumanoidRootPart")
                if bone then
                    local sp, onScreen = cam:WorldToViewportPoint(bone.Position)
                    if onScreen then
                        candidates[#candidates+1] = {
                            player  = p,
                            bone    = bone,
                            hp      = hum.Health,
                            dist    = (camPos - bone.Position).Magnitude,
                            screenDist = (Vector2.new(sp.X, sp.Y) - Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)).Magnitude,
                        }
                    end
                end
            end
        end
    end

    if #candidates == 0 then return nil end

    if mode == "Closest" then
        table.sort(candidates, function(a,b) return a.screenDist < b.screenDist end)
    elseif mode == "Lowest HP" then
        table.sort(candidates, function(a,b) return a.hp < b.hp end)
    elseif mode == "Highest HP" then
        table.sort(candidates, function(a,b) return a.hp > b.hp end)
    elseif mode == "Random" then
        local i = math.random(1, #candidates)
        return candidates[i].player, candidates[i].bone
    elseif mode == "Nearest Dist" then
        table.sort(candidates, function(a,b) return a.dist < b.dist end)
    end

    return candidates[1].player, candidates[1].bone
end

local function stopRagebot()
    if ragebotConn then ragebotConn:Disconnect(); ragebotConn = nil end
    ragebotFiring = false
end

local function startRagebot()
    stopRagebot()
    ragebotConn = RunService.Heartbeat:Connect(function()
        if not state.ragebotEnabled or ragebotFiring then return end

        -- Hitchance gate
        if math.random(1, 100) > state.ragebotHitchance then return end

        local cam = workspace.CurrentCamera
        local target, bone = getRagebotTarget()
        if not target or not bone then return end

        -- Velocity prediction: offset aim by estimated travel time
        local bonePos = bone.Position
        if state.ragebotPrediction then
            local hrp = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local vel = hrp.AssemblyLinearVelocity or Vector3.zero
                local dist = (cam.CFrame.Position - bonePos).Magnitude
                local travelTime = dist / 300  -- ~300 stud/s bullet approx
                bonePos = bonePos + vel * travelTime
            end
        end

        -- Snap camera to target
        local origCF = cam.CFrame
        cam.CFrame = CFrame.new(origCF.Position, bonePos)

        ragebotFiring = true
        task.spawn(function()
            -- First shot
            safeFire()

            -- Doubleshot: fire a second time after a short gap
            if state.ragebotDoubleshot then
                task.wait(0.05)
                safeFire()
            end

            -- Hold delay then allow next shot
            task.wait(math.max(0.016, state.ragebotDelay / 1000))
            cam.CFrame = origCF
            ragebotFiring = false
        end)
    end)
end

